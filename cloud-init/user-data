#cloud-config

hostname: server
fqdn: server.lan
locale: en_US.UTF-8
timezone: UTC

keyboard:
  layout: us

users:
  - name: admin
    gecos: System Administrator
    groups: [sudo, ssh-users, docker, tcpdump]
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    lock_passwd: false
    shell: /bin/bash

groups: [ssh-users, docker, tcpdump]

chpasswd:
  expire: true
  users:
  - {name: admin, password: password, type: text}

ssh_pwauth: true
disable_root: true

package_update: true
package_upgrade: true
package_reboot_if_required: true

packages:
  - openssh-server
  - ufw
  - fail2ban
  - tcpdump
  - lastlog2
  - curl
  - wget
  - git
  - zip
  - unzip
  - top
  - htop
  - btop
  - screen
  - traceroute
  - dnsutils
  - whois
  - mtr-tiny
  - build-essential

apt:
  preserve_sources_list: true

ntp:
  enabled: true
  ntp_client: auto
  servers:
    - "0.pool.ntp.org"
    - "1.pool.ntp.org"
    - "2.pool.ntp.org"
    - "3.pool.ntp.org"

ssh_deletekeys: true
allow_public_ssh_keys: false
ssh_genkeytypes: [rsa, ecdsa, ed25519]
ssh_quiet_keygen: true

ssh_publish_hostkeys:
  enabled: false

manage_etc_hosts: localhost
manage_resolv_conf: false
preserve_hostname: false
create_hostname_file: true
prefer_fqdn_over_hostname: true

growpart:
  devices: [/]
  mode: auto
  ignore_growroot_disabled: false

resize_rootfs: noblock

rpi:
  enable_usb_gadget: false
  interfaces:
    spi: false
    i2c: false
    onewire: false
    serial:
      console: false
      hardware: false

write_files:
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/config.txt
  defer: true
  path: /boot/firmware/config.txt
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/sysctl.conf
  defer: true
  path: /etc/sysctl.conf
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/console-setup
  defer: true
  path: /etc/default/console-setup
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/logind.conf
  defer: true
  path: /etc/systemd/logind.conf
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/sshd_config
  defer: true
  path: /etc/ssh/sshd_config.d/10-sshd_config.conf
  append: false
  owner: root:root
  permissions: '0600'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/IP.issue
  defer: true
  path: /etc/issue.d/IP.issue
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/issue
  defer: true
  path: /etc/issue
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/motd
  defer: true
  path: /etc/motd
  append: false
  owner: root:root
  permissions: '0644'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/motd-system
  defer: true
  path: /etc/update-motd.d/motd-system
  append: false
  owner: root:root
  permissions: '0755'
- source:
    uri: https://raw.githubusercontent.com/pi-init/auto-setup-pi5-argon-neo5-nvme/refs/heads/main/configs/jail.local
  defer: true
  path: /etc/fail2ban/jail.local
  append: false
  owner: root:root
  permissions: '0644'

byobu_by_default: disable-system
disable_ec2_metadata: true

runcmd:
  - rm -- /etc/update-motd.d/[0-9][0-9]-*
  - sed -i '$ s/$/ loglevel=3 ipv6.disable=1 logo.nologo/' /boot/firmware/cmdline.txt
  - sed -i 's/^IPV6=.*/IPV6=no/' /etc/default/ufw || echo 'IPV6=no' >> /etc/default/ufw
  - ufw default allow outgoing
  - ufw default deny incoming
  - ufw default deny routed
  - ufw allow from 10.0.0.0/8 to any port 22 proto tcp
  - ufw allow from 172.16.0.0/12 to any port 22 proto tcp
  - ufw allow from 192.168.0.0/16 to any port 22 proto tcp
  - ufw --force enable
  - systemctl enable --now fail2ban
  - systemctl enable --now ssh

bootcmd:
  - sysctl net.ipv6.conf.all.disable_ipv6=1

final_message: |
  The Raspberry Pi 5 cloud-init process has finished!
  Timestamp: $timestamp
  Uptime: $uptime
  Version: $version

power_state:
  delay: now
  mode: poweroff
